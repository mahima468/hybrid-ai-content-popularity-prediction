        };
      case 'not_ready':
        return {
          color: '#f44336',
          bgColor: 'rgba(244, 67, 54, 0.15)',
          borderColor: 'rgba(244, 67, 54, 0.3)',
          icon: <Error sx={{ fontSize: 16 }} />,
          label: 'Not Ready'
        };
      case 'training':
      case 'loading':
        return {
          color: '#ff9800',
          bgColor: 'rgba(255, 152, 0, 0.15)',
          borderColor: 'rgba(255, 152, 0, 0.3)',
          icon: <Warning sx={{ fontSize: 16 }} />,
          label: 'Loading'
        };
      case 'Disconnected':
        return {
          color: '#f44336',
          bgColor: 'rgba(244, 67, 54, 0.15)',
          borderColor: 'rgba(244, 67, 54, 0.3)',
          icon: <Error sx={{ fontSize: 16 }} />,
          label: 'Disconnected'
        };
      default:
        return {
          color: '#9e9e9e',
          bgColor: 'rgba(158, 158, 158, 0.15)',
          borderColor: 'rgba(158, 158, 158, 0.3)',
          icon: <Circle sx={{ fontSize: 16 }} />,
          label: 'Unknown'
        };
    }
  };
  const navigate = useNavigate();
  const [systemStatus, setSystemStatus] = useState({
    sentimentModel: 'Loading...',
    engagementModel: 'Loading...',
    popularityModel: 'Loading...',
    apiStatus: 'Connected'
  });
  const [recentAnalyses, setRecentAnalyses] = useState([]);
  const [loading, setLoading] = useState(false);
  const [downloading, setDownloading] = useState(false);
  const [analyticsData, setAnalyticsData] = useState(null);
  const [analyticsError, setAnalyticsError] = useState('');

  // Safe data with fallbacks to prevent crashes
  const safeAnalyticsData = analyticsData || {
    total_views: 0,
    avg_engagement: 0,
    avg_sentiment: 0,
    total_content: 0,
    sentiment_accuracy: 0,
    predictions_summary: {
      total_predictions: 0,
      avg_predicted_views: 0,
      max_predicted_views: 0,
      min_predicted_views: 0
    },
    sentiment_distribution: {
      positive: 0,
      neutral: 0,
      negative: 0
    },
    engagement_authenticity: {
      real_engagement: 0,
      fake_engagement: 0
    },
    top_performing_content: []
  };

  // Chart data for Recharts
  const [sentimentData, setSentimentData] = useState([
    { name: 'Positive', value: 0, color: '#4caf50' },
    { name: 'Neutral', value: 0, color: '#ff9800' },
    { name: 'Negative', value: 0, color: '#f44336' }
  ]);

  const [popularityData, setPopularityData] = useState([
    { month: 'Jan', predicted: 0, actual: 0 },
    { month: 'Feb', predicted: 0, actual: 0 },
    { month: 'Mar', predicted: 0, actual: 0 },
    { month: 'Apr', predicted: 0, actual: 0 },
    { month: 'May', predicted: 0, actual: 0 },
    { month: 'Jun', predicted: 0, actual: 0 }
  ]);

  const [engagementData, setEngagementData] = useState([
    { type: 'High Engagement', engagement: 0, color: '#4caf50' },
    { type: 'Medium Engagement', engagement: 0, color: '#ff9800' },
    { type: 'Low Engagement', engagement: 0, color: '#f44336' }
  ]);

  const [categoryData, setCategoryData] = useState([
    { category: 'Entertainment', count: 0, color: '#e91e63' },
    { category: 'Education', count: 0, color: '#3f51b5' },
    { category: 'Technology', count: 0, color: '#00bcd4' },
    { category: 'Sports', count: 0, color: '#4caf50' },
    { category: 'News', count: 0, color: '#ff9800' }
  ]);

  const [engagementAuthenticityData, setEngagementAuthenticityData] = useState([
    { name: 'Real Engagement', value: 0, color: '#4caf50' },
    { name: 'Fake Engagement', value: 0, color: '#f44336' }
  ]);

  const [chartData, setChartData] = useState({
    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
    datasets: [
      {
        label: 'Predicted Popularity',
        data: [0, 0, 0, 0, 0, 0],
        borderColor: 'rgba(54, 162, 235, 1)',
        backgroundColor: 'rgba(54, 162, 235, 0.2)',
        tension: 0.3,
      },
      {
        label: 'Actual Popularity',
        data: [0, 0, 0, 0, 0, 0],
        borderColor: 'rgba(255, 99, 132, 1)',
        backgroundColor: 'rgba(255, 99, 132, 0.2)',
        tension: 0.3,
      },
    ],
  });

  const chartOptions = {
    responsive: true,
    plugins: {
      legend: {
        position: 'top',
      },
      title: {
        display: true,
        text: 'Content Popularity Trends',
      },
    },
  };

  useEffect(() => {
    fetchSystemStatus();
    fetchRecentAnalyses();
    fetchAnalyticsData();
  }, []);

  const fetchAnalyticsData = async (retryCount = 0) => {
    try {
      setLoading(true);
      setAnalyticsError('');
      
      // Add timeout using AbortController
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000); // 5 second timeout
      
      const response = await fetch(API_ENDPOINTS.DASHBOARD_ANALYTICS, {
        headers: {
          'Content-Type': 'application/json',
        },
        signal: controller.signal
      });
      
      clearTimeout(timeoutId);
      
      if (!response.ok) {
        throw new Error(`API call failed: ${response.status} ${response.statusText}`);
      }

      const analytics = await response.json();
      console.log('Dashboard analytics response:', analytics);
      setAnalyticsData(analytics);
      
      // Update sentiment distribution chart
      if (analytics.sentiment_distribution) {
        setSentimentData([
          { name: 'Positive', value: analytics.sentiment_distribution.positive || 0, color: '#4caf50' },
          { name: 'Neutral', value: analytics.sentiment_distribution.neutral || 0, color: '#ff9800' },
          { name: 'Negative', value: analytics.sentiment_distribution.negative || 0, color: '#f44336' }
        ]);
      }
      
      // Update engagement authenticity chart
      if (analytics.engagement_authenticity) {
        setEngagementAuthenticityData([
          { name: 'Real Engagement', value: analytics.engagement_authenticity.real || 0, color: '#4caf50' },
          { name: 'Fake Engagement', value: analytics.engagement_authenticity.fake || 0, color: '#f44336' }
        ]);
      }
      
      // Update popularity trends chart
      if (analytics.popularity_trends) {
        const months = analytics.popularity_trends.labels || ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'];
        const predicted = analytics.popularity_trends.predicted || [65, 72, 78, 85, 89, 92];
        const actual = analytics.popularity_trends.actual || [60, 68, 75, 82, 85, 88];
        
        setPopularityData(
          months.map((month, index) => ({
            month,
            predicted: predicted[index] || 0,
            actual: actual[index] || 0
          }))
        );
      }
      
      // Update engagement chart
      if (analytics.avg_engagement) {
        setEngagementData([
          { type: 'High Engagement', engagement: analytics.avg_engagement * 100 || 75, color: '#4caf50' },
          { type: 'Medium Engagement', engagement: (analytics.avg_engagement * 100 * 0.7) || 52, color: '#ff9800' },
          { type: 'Low Engagement', engagement: (analytics.avg_engagement * 100 * 0.4) || 30, color: '#f44336' }
        ]);
      }
      
      // Update category chart
      if (analytics.content_categories) {
        setCategoryData([
          { category: 'Entertainment', count: analytics.content_categories.entertainment || 12500, color: '#e91e63' },
          { category: 'Education', count: analytics.content_categories.education || 8900, color: '#3f51b5' },
          { category: 'Technology', count: analytics.content_categories.technology || 15600, color: '#00bcd4' },
          { category: 'Sports', count: analytics.content_categories.sports || 11200, color: '#4caf50' },
          { category: 'News', count: analytics.content_categories.news || 7800, color: '#ff9800' }
        ]);
      } else {
        // Default category data
        setCategoryData([
          { category: 'Entertainment', count: 12500, color: '#e91e63' },
          { category: 'Education', count: 8900, color: '#3f51b5' },
          { category: 'Technology', count: 15600, color: '#00bcd4' },
          { category: 'Sports', count: 11200, color: '#4caf50' },
          { category: 'News', count: 7800, color: '#ff9800' }
        ]);
      }
      
    } catch (error) {
      console.error('Error fetching analytics data:', error);
      
      // Retry logic - try up to 2 times
      if (retryCount < 2) {
        console.log(`Retrying fetchAnalyticsData (attempt ${retryCount + 1}/2)`);
        setTimeout(() => fetchAnalyticsData(retryCount + 1), 1000 * (retryCount + 1)); // Exponential backoff
        return;
      }
      
      setAnalyticsError('Failed to load analytics data after multiple attempts');
    } finally {
      setLoading(false);
    }
  };

  const fetchSystemStatus = async () => {
    try {
      const status = await apiCall(API_ENDPOINTS.MODEL_STATUS);
      
      // Process model status using shared utility
      const processedStatus = processModelStatus(status);
      setSystemStatus(processedStatus);
      
    } catch (error) {
      console.error('Error fetching model status:', error);
      setSystemStatus({
        sentimentModel: 'Error',
        engagementModel: 'Error',
        popularityModel: 'Error',
        apiStatus: 'Disconnected'
      });
    }
  };

  const fetchRecentAnalyses = async () => {
    try {
      const analytics = await apiCall(API_ENDPOINTS.DASHBOARD_ANALYTICS);
      
      // Create recent analyses from analytics data
      const analyses = [
        { 
          id: 1, 
          type: 'Sentiment Analysis', 
          status: 'Completed', 
          timestamp: new Date().toLocaleString(), 
          accuracy: `${(analytics.sentiment_accuracy * 100).toFixed(1)}%` 
        },
        { 
          id: 2, 
          type: 'Engagement Detection', 
          status: 'Completed', 
          timestamp: new Date().toLocaleString(), 
          accuracy: `${(analytics.engagement_accuracy * 100).toFixed(1)}%` 
        },
        { 
          id: 3, 
          type: 'Popularity Prediction', 
          status: 'Completed', 
          timestamp: new Date().toLocaleString(), 
          accuracy: `${(analytics.prediction_accuracy * 100).toFixed(1)}%` 
        },
      ];
      
      setRecentAnalyses(analyses);
      
    } catch (error) {
      console.error('Error fetching recent analyses:', error);
      setRecentAnalyses([]);
    }
  };

  const getStatusColor = (status) => {
    return getStatusColorUtil(status);
  };

  const handleRefresh = () => {
    setLoading(true);
    fetchSystemStatus();
    fetchRecentAnalyses();
    fetchAnalyticsData();
    setTimeout(() => setLoading(false), 1000);
  };

  const handleDownloadReport = async () => {
    setDownloading(true);
    try {
      const url = `${API_CONFIG.BASE_URL}/download-report`;
      
      const response = await fetch(url);
      
      if (!response.ok) {
        throw new Error(`Download failed: ${response.status} ${response.statusText}`);
      }

      // Convert response to blob
      const blob = await response.blob();
      
      // Create download URL
      const downloadUrl = window.URL.createObjectURL(blob);
      
      // Create temporary link and trigger download
      const link = document.createElement('a');
      link.href = downloadUrl;
      link.download = 'analytics_report.csv';
      document.body.appendChild(link);
      link.click();
      
      // Clean up
      document.body.removeChild(link);
      window.URL.revokeObjectURL(downloadUrl);
      
      console.log('Report downloaded successfully');
    } catch (error) {
      console.error('Error downloading report:', error);
      // You could add error handling here, like showing a snackbar
      alert('Failed to download report. Please try again.');
    } finally {
      setDownloading(false);
    }
  };

  return (
    <ErrorBoundary>
      <>
        {/* Loading and Error States */}
        {loading && (
          <Box sx={{ 
            display: 'flex', 
            justifyContent: 'center', 
            alignItems: 'center', 
            minHeight: '100vh',
            background: 'linear-gradient(135deg, #667eea 0%, #764ba2 25%, #f093fb 50%, #c471f5 75%, #667eea 100%)'
          }}>
            <Typography variant="h6" sx={{ color: 'white' }}>
              Loading Dashboard...
            </Typography>
