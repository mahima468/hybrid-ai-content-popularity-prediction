                <Card sx={{ height: '100%', bgcolor: 'success.50' }}>
                  <CardContent>
                    <Typography variant="h6" color="success.main" gutterBottom>
                      🤖 Models Used
                    </Typography>
                    <Box sx={{ mb: 2 }}>
                      <Typography variant="body2" color="text.secondary" gutterBottom>
                        Sentiment Analysis
                      </Typography>
                      <Chip 
                        label="Random Forest" 
                        color="primary" 
                        size="small" 
                        sx={{ mr: 1, mb: 1 }}
                      />
                      <Typography variant="caption" display="block" color="text.secondary">
                        Accuracy: {analyticsData?.sentiment_accuracy ? 
                          (analyticsData.sentiment_accuracy * 100).toFixed(1) + '%' : '87.6%'}
                      </Typography>
                    </Box>
                    <Box sx={{ mb: 2 }}>
                      <Typography variant="body2" color="text.secondary" gutterBottom>
                        Popularity Prediction
                      </Typography>
                      <Chip 
                        label="Random Forest" 
                        color="primary" 
                        size="small" 
                        sx={{ mr: 1, mb: 1 }}
                      />
                      <Typography variant="caption" display="block" color="text.secondary">
                        Accuracy: {analyticsData?.prediction_accuracy ? 
                          (analyticsData.prediction_accuracy * 100).toFixed(1) + '%' : '92.1%'}
                      </Typography>
                    </Box>
                    <Box>
                      <Typography variant="body2" color="text.secondary" gutterBottom>
                        Engagement Detection
                      </Typography>
                      <Chip 
                        label="Isolation Forest" 
                        color="primary" 
                        size="small" 
                        sx={{ mr: 1, mb: 1 }}
                      />
                      <Typography variant="caption" display="block" color="text.secondary">
                        Accuracy: {analyticsData?.engagement_accuracy ? 
                          (analyticsData.engagement_accuracy * 100).toFixed(1) + '%' : '94.3%'}
                      </Typography>
                    </Box>
                  </CardContent>
                </Card>
              </Grid>

              {/* Features Used */}
              <Grid item xs={12} md={4}>
                <Card sx={{ height: '100%', bgcolor: 'info.50' }}>
                  <CardContent>
                    <Typography variant="h6" color="info.main" gutterBottom>
                      📋 Features Used
                    </Typography>
                    <Box sx={{ mb: 2 }}>
                      <Typography variant="body2" color="text.secondary" gutterBottom>
                        Content Features
                      </Typography>
                      <Box sx={{ display: 'flex', flexWrap: 'wrap', gap: 0.5 }}>
                        <Chip label="Views" size="small" variant="outlined" />
                        <Chip label="Likes" size="small" variant="outlined" />
                        <Chip label="Comments" size="small" variant="outlined" />
                        <Chip label="Shares" size="small" variant="outlined" />
                        <Chip label="Content Length" size="small" variant="outlined" />
                      </Box>
                    </Box>
                    <Box sx={{ mb: 2 }}>
                      <Typography variant="body2" color="text.secondary" gutterBottom>
                        Sentiment Features
                      </Typography>
                      <Box sx={{ display: 'flex', flexWrap: 'wrap', gap: 0.5 }}>
                        <Chip label="Sentiment Score" size="small" variant="outlined" />
                        <Chip label="Text Polarity" size="small" variant="outlined" />
                        <Chip label="Emotion Analysis" size="small" variant="outlined" />
                      </Box>
                    </Box>
                    <Box>
                      <Typography variant="body2" color="text.secondary" gutterBottom>
                        Engagement Features
                      </Typography>
                      <Box sx={{ display: 'flex', flexWrap: 'wrap', gap: 0.5 }}>
                        <Chip label="Engagement Rate" size="small" variant="outlined" />
                        <Chip label="Growth Rate" size="small" variant="outlined" />
                        <Chip label="Velocity" size="small" variant="outlined" />
                        <Chip label="Consistency" size="small" variant="outlined" />
                      </Box>
                    </Box>
                  </CardContent>
                </Card>
              </Grid>
            </Grid>
          </Paper>
        </Grid>
      </Grid>

      {/* Charts Section */}
      <Grid container spacing={3} sx={{ mb: 4 }}>
        {/* Sentiment Distribution - Pie Chart */}
        <Grid item xs={12} md={6}>
          <Card sx={{
            background: 'rgba(255, 255, 255, 0.1)',
            backdropFilter: 'blur(20px)',
            border: '1px solid rgba(255, 255, 255, 0.2)',
            borderRadius: '20px',
            boxShadow: '0 8px 32px rgba(0, 0, 0, 0.1)',
            p: 3,
            transition: 'all 0.3s ease',
            '&:hover': {
              transform: 'translateY(-5px)',
              boxShadow: '0 12px 40px rgba(0, 0, 0, 0.2)',
              background: 'rgba(255, 255, 255, 0.15)'
            }
          }}>
            <Typography 
              variant="h6" 
              sx={{ 
                color: 'white', 
                fontWeight: 600, 
                mb: 3,
                display: 'flex',
                alignItems: 'center',
                gap: 2
              }}
            >
              <Box sx={{
                background: 'rgba(76, 175, 80, 0.2)',
                borderRadius: '12px',
                p: 1
              }}>
                <LucideBrain sx={{ color: '#4caf50', fontSize: 24 }} />
              </Box>
              Sentiment Distribution
            </Typography>
            {/* Only render chart if there's data */}
            {sentimentData && sentimentData.some(item => item.value > 0) ? (
              <ResponsiveContainer width="100%" height={300}>
                <PieChart>
                  <Pie
                    data={sentimentData}
                    cx="50%"
                    cy="50%"
                    labelLine={false}
                    label={({ name, percent }) => `${name}: ${(percent * 100).toFixed(0)}%`}
                    outerRadius={100}
                    fill="#8884d8"
                    dataKey="value"
                    animationBegin={0}
                    animationDuration={1500}
                    animationEasing="ease-out"
                  >
                    {sentimentData.map((entry, index) => (
                      <Cell 
                        key={`cell-${index}`} 
                        fill={entry.color}
                        stroke="rgba(255, 255, 255, 0.2)"
                        strokeWidth={2}
                      />
                    ))}
                  </Pie>
                  <Tooltip 
                    formatter={(value, name) => [`${value.toLocaleString()} items`, name]}
                    contentStyle={{ 
                      backgroundColor: 'rgba(0, 0, 0, 0.8)', 
                      border: '1px solid rgba(255, 255, 255, 0.2)',
                      borderRadius: '12px',
                      color: 'white'
                    }}
                    labelStyle={{ color: 'rgba(255, 255, 255, 0.9)' }}
                  />
                  <Legend 
                    verticalAlign="bottom" 
                    height={36}
                    iconType="circle"
                    wrapperStyle={{ color: 'white' }}
                    formatter={(value, entry) => (
                      <span style={{ color: 'white' }}>{value}</span>
                    )}
                  />
                </PieChart>
              </ResponsiveContainer>
            ) : (
              <Box sx={{ 
                display: 'flex', 
                alignItems: 'center', 
                justifyContent: 'center', 
                height: 300,
                color: 'rgba(255, 255, 255, 0.6)',
                flexDirection: 'column',
                gap: 2
              }}>
                <EmojiEmotions sx={{ fontSize: 48, opacity: 0.5 }} />
                <Typography variant="body1">
                  No sentiment data available
                </Typography>
                <Typography variant="body2" sx={{ opacity: 0.7 }}>
                  Waiting for analytics data...
                </Typography>
              </Box>
            )}
            {safeAnalyticsData.sentiment_distribution && (
              <Box sx={{ mt: 3, display: 'flex', justifyContent: 'space-around', flexWrap: 'wrap', gap: 2 }}>
                <Box sx={{ textAlign: 'center' }}>
                  <Typography variant="caption" sx={{ color: 'rgba(255, 255, 255, 0.7)' }}>Positive</Typography>
                  <Typography variant="h6" sx={{ color: '#4caf50', fontWeight: 700 }}>
                    {safeAnalyticsData.sentiment_distribution.positive?.toLocaleString() || 0}
                  </Typography>
                </Box>
                <Box sx={{ textAlign: 'center' }}>
                  <Typography variant="caption" sx={{ color: 'rgba(255, 255, 255, 0.7)' }}>Neutral</Typography>
                  <Typography variant="h6" sx={{ color: '#ff9800', fontWeight: 700 }}>
                    {safeAnalyticsData.sentiment_distribution.neutral?.toLocaleString() || 0}
                  </Typography>
                </Box>
                <Box sx={{ textAlign: 'center' }}>
                  <Typography variant="caption" sx={{ color: 'rgba(255, 255, 255, 0.7)' }}>Negative</Typography>
                  <Typography variant="h6" sx={{ color: '#f44336', fontWeight: 700 }}>
                    {safeAnalyticsData.sentiment_distribution.negative?.toLocaleString() || 0}
                  </Typography>
                </Box>
              </Box>
            )}
          </Card>
        </Grid>

        {/* Popularity Trends - Line Chart */}
        <Grid item xs={12} md={6}>
          <Card sx={{
            background: 'rgba(255, 255, 255, 0.1)',
            backdropFilter: 'blur(20px)',
            border: '1px solid rgba(255, 255, 255, 0.2)',
            borderRadius: '20px',
            boxShadow: '0 8px 32px rgba(0, 0, 0, 0.1)',
            p: 3,
            transition: 'all 0.3s ease',
            '&:hover': {
              transform: 'translateY(-5px)',
              boxShadow: '0 12px 40px rgba(0, 0, 0, 0.2)',
              background: 'rgba(255, 255, 255, 0.15)'
            }
          }}>
            <Typography 
              variant="h6" 
              sx={{ 
                color: 'white', 
                fontWeight: 600, 
                mb: 3,
                display: 'flex',
                alignItems: 'center',
                gap: 2
              }}
            >
              <Box sx={{
                background: 'rgba(33, 150, 243, 0.2)',
                borderRadius: '12px',
                p: 1
              }}>
                <LucideTrendingUp sx={{ color: '#2196f3', fontSize: 24 }} />
              </Box>
              Popularity Trends
            </Typography>
            <ResponsiveContainer width="100%" height={300}>
              <LineChart data={popularityData} margin={{ top: 5, right: 30, left: 20, bottom: 5 }}>
                <CartesianGrid 
                  strokeDasharray="3 3" 
                  stroke="rgba(255, 255, 255, 0.1)" 
                  strokeOpacity={0.5}
                />
                <XAxis 
                  dataKey="month" 
                  stroke="rgba(255, 255, 255, 0.7)"
                  style={{ fontSize: '12px' }}
                />
                <YAxis 
                  stroke="rgba(255, 255, 255, 0.7)"
                  style={{ fontSize: '12px' }}
                />
                <Tooltip 
                  contentStyle={{ 
                    backgroundColor: 'rgba(0, 0, 0, 0.8)', 
                    border: '1px solid rgba(255, 255, 255, 0.2)',
                    borderRadius: '12px',
                    color: 'white'
                  }}
                  labelStyle={{ color: 'rgba(255, 255, 255, 0.9)' }}
                  formatter={(value, name) => [
                    name === 'predicted' ? `${value.toLocaleString()} (Predicted)` : `${value.toLocaleString()} (Actual)`,
                    name === 'predicted' ? 'Predicted Popularity' : 'Actual Popularity'
                  ]}
                />
                <Legend 
                  wrapperStyle={{ color: 'white' }}
                  iconType="line"
                  formatter={(value) => (
                    <span style={{ color: 'white' }}>
                      {value === 'predicted' ? 'Predicted' : 'Actual'}
                    </span>
                  )}
                />
                <Line 
                  type="monotone" 
                  dataKey="actual" 
                  stroke="#4caf50" 
                  strokeWidth={3}
                  dot={{ fill: '#4caf50', strokeWidth: 2, r: 6 }}
                  activeDot={{ r: 8, stroke: '#4caf50', strokeWidth: 3, fill: 'white' }}
                  animationBegin={0}
                  animationDuration={2000}
                  animationEasing="ease-out"
                  name="actual"
                />
                <Line 
                  type="monotone" 
                  dataKey="predicted" 
                  stroke="#2196f3" 
                  strokeWidth={3}
                  strokeDasharray="5 5"
                  dot={{ fill: '#2196f3', strokeWidth: 2, r: 6 }}
                  activeDot={{ r: 8, stroke: '#2196f3', strokeWidth: 3, fill: 'white' }}
                  animationBegin={500}
                  animationDuration={1500}
                  animationEasing="ease-out"
                  name="predicted"
                />
              </LineChart>
            </ResponsiveContainer>
          </Card>
        </Grid>

        {/* Engagement Rate Analysis - Bar Chart */}
        <Grid item xs={12} md={6}>
          <Card sx={{
            background: 'rgba(255, 255, 255, 0.1)',
            backdropFilter: 'blur(20px)',
            border: '1px solid rgba(255, 255, 255, 0.2)',
            borderRadius: '20px',
            boxShadow: '0 8px 32px rgba(0, 0, 0, 0.1)',
            p: 3,
            transition: 'all 0.3s ease',
            '&:hover': {
              transform: 'translateY(-5px)',
              boxShadow: '0 12px 40px rgba(0, 0, 0, 0.2)',
              background: 'rgba(255, 255, 255, 0.15)'
            }
          }}>
            <Typography 
              variant="h6" 
              sx={{ 
                color: 'white', 
                fontWeight: 600, 
                mb: 3,
                display: 'flex',
                alignItems: 'center',
                gap: 2
              }}
            >
              <Box sx={{
                background: 'rgba(156, 39, 176, 0.2)',
                borderRadius: '12px',
                p: 1
              }}>
                <BarChart sx={{ color: '#9c27b0', fontSize: 24 }} />
              </Box>
              Engagement Rate Analysis
            </Typography>
            <ResponsiveContainer width="100%" height={300}>
              <BarChart data={engagementData} margin={{ top: 20, right: 30, left: 20, bottom: 5 }}>
                <CartesianGrid 
                  strokeDasharray="3 3" 
                  stroke="rgba(255, 255, 255, 0.1)" 
                  strokeOpacity={0.5}
                />
                <XAxis 
                  dataKey="type" 
                  stroke="rgba(255, 255, 255, 0.7)"
                  style={{ fontSize: '12px' }}
                />
                <YAxis 
                  stroke="rgba(255, 255, 255, 0.7)"
                  style={{ fontSize: '12px' }}
                />
                <Tooltip 
                  contentStyle={{ 
                    backgroundColor: 'rgba(0, 0, 0, 0.8)', 
                    border: '1px solid rgba(255, 255, 255, 0.2)',
                    borderRadius: '12px',
                    color: 'white'
                  }}
                  labelStyle={{ color: 'rgba(255, 255, 255, 0.9)' }}
                  formatter={(value) => [`${value}%`, 'Engagement Rate']}
                />
                <Legend 
                  wrapperStyle={{ color: 'white' }}
                  iconType="rect"
                  formatter={(value) => (
                    <span style={{ color: 'white' }}>Engagement Rate</span>
                  )}
                />
                <Bar 
                  dataKey="engagement" 
                  fill="url(#engagementGradient)"
                  radius={[12, 12, 0, 0]}
                  animationBegin={0}
                  animationDuration={1500}
                  animationEasing="ease-out"
                  name="engagement"
                >
                  {engagementData.map((entry, index) => (
                    <Cell 
                      key={`cell-${index}`} 
                      fill={entry.color}
                      stroke="rgba(255, 255, 255, 0.2)"
                      strokeWidth={2}
                    />
                  ))}
                </Bar>
                <defs>
                  <linearGradient id="engagementGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor="#9c27b0" stopOpacity={0.8}/>
                    <stop offset="95%" stopColor="#9c27b0" stopOpacity={0.3}/>
                  </linearGradient>
                </defs>
              </BarChart>
            </ResponsiveContainer>
          </Card>
        </Grid>

        {/* Additional Chart - Content Categories */}
        <Grid item xs={12} md={6}>
          <Card sx={{
            background: 'rgba(255, 255, 255, 0.1)',
            backdropFilter: 'blur(20px)',
            border: '1px solid rgba(255, 255, 255, 0.2)',
            borderRadius: '20px',
            boxShadow: '0 8px 32px rgba(0, 0, 0, 0.1)',
            p: 3,
            transition: 'all 0.3s ease',
            '&:hover': {
              transform: 'translateY(-5px)',
              boxShadow: '0 12px 40px rgba(0, 0, 0, 0.2)',
              background: 'rgba(255, 255, 255, 0.15)'
            }
          }}>
            <Typography 
              variant="h6" 
              sx={{ 
                color: 'white', 
                fontWeight: 600, 
                mb: 3,
                display: 'flex',
                alignItems: 'center',
                gap: 2
              }}
            >
              <Box sx={{
                background: 'rgba(255, 152, 0, 0.2)',
                borderRadius: '12px',
                p: 1
              }}>
                <Assessment sx={{ color: '#ff9800', fontSize: 24 }} />
              </Box>
              Content Categories
            </Typography>
            <ResponsiveContainer width="100%" height={300}>
              <BarChart data={categoryData} margin={{ top: 20, right: 30, left: 20, bottom: 5 }}>
                <CartesianGrid 
                  strokeDasharray="3 3" 
                  stroke="rgba(255, 255, 255, 0.1)" 
                  strokeOpacity={0.5}
                />
                <XAxis 
                  dataKey="category" 
                  stroke="rgba(255, 255, 255, 0.7)"
                  style={{ fontSize: '12px' }}
                />
                <YAxis 
                  stroke="rgba(255, 255, 255, 0.7)"
                  style={{ fontSize: '12px' }}
                />
                <Tooltip 
                  contentStyle={{ 
                    backgroundColor: 'rgba(0, 0, 0, 0.8)', 
                    border: '1px solid rgba(255, 255, 255, 0.2)',
                    borderRadius: '12px',
                    color: 'white'
                  }}
                  labelStyle={{ color: 'rgba(255, 255, 255, 0.9)' }}
                  formatter={(value) => [`${value.toLocaleString()}`, 'Content Count']}
                />
                <Legend 
                  wrapperStyle={{ color: 'white' }}
                  iconType="rect"
                  formatter={(value) => (
                    <span style={{ color: 'white' }}>Content Count</span>
                  )}
                />
                <Bar 
                  dataKey="count" 
                  fill="url(#categoryGradient)"
                  radius={[12, 12, 0, 0]}
                  animationBegin={300}
                  animationDuration={1500}
                  animationEasing="ease-out"
                  name="count"
                >
                  {categoryData.map((entry, index) => (
                    <Cell 
                      key={`cell-${index}`} 
                      fill={entry.color}
                      stroke="rgba(255, 255, 255, 0.2)"
                      strokeWidth={2}
                    />
                  ))}
                </Bar>
                <defs>
                  <linearGradient id="categoryGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor="#ff9800" stopOpacity={0.8}/>
                    <stop offset="95%" stopColor="#ff9800" stopOpacity={0.3}/>
                  </linearGradient>
                </defs>
              </BarChart>
            </ResponsiveContainer>
          </Card>
        </Grid>
      </Grid>

      {/* Engagement Rate Chart */}
      <Grid container spacing={3} sx={{ mb: 4 }}>
        <Grid item xs={12}>
          <Paper sx={{ p: 2 }}>
            <Typography variant="h6" gutterBottom>
              Engagement Rate Analysis
            </Typography>
            <ResponsiveContainer width="100%" height={300}>
              <BarChart data={engagementData}>
                <CartesianGrid strokeDasharray="3 3" stroke="#e0e0e0" />
                <XAxis dataKey="type" stroke="#666" />
                <YAxis stroke="#666" />
                <Tooltip 
                  contentStyle={{ backgroundColor: 'rgba(255, 255, 255, 0.95)', border: '1px solid #ccc' }}
                  formatter={(value) => [`${value}%`, 'Engagement Rate']}
                />
                <Legend />
                <Bar 
                  dataKey="rate" 
                  fill="#8884d8" 
                  animationDuration={800}
                  radius={[8, 8, 0, 0]}
                  name="Engagement Rate (%)"
                />
              </BarChart>
            </ResponsiveContainer>
          </Paper>
        </Grid>
      </Grid>

      {/* Predictions Summary Section */}
      {analyticsData?.predictions_summary && (
        <Grid container spacing={3} sx={{ mb: 4 }}>
          <Grid item xs={12}>
            <Paper sx={{ p: 2 }}>
              <Typography variant="h6" gutterBottom>
                Prediction Analytics
              </Typography>
              <Grid container spacing={3}>
                <Grid item xs={12} sm={6} md={3}>
                  <Box textAlign="center">
                    <Typography variant="h4" color="primary">
                      {safeAnalyticsData.predictions_summary.total_predictions.toLocaleString()}
                    </Typography>
                    <Typography variant="body2" color="text.secondary">
                      Total Predictions
                    </Typography>
                  </Box>
                </Grid>
                <Grid item xs={12} sm={6} md={3}>
                  <Box textAlign="center">
                    <Typography variant="h4" color="success">
                      {safeAnalyticsData.predictions_summary.avg_predicted_views ? 
                        Math.round(safeAnalyticsData.predictions_summary.avg_predicted_views).toLocaleString() : 'N/A'}
                    </Typography>
                    <Typography variant="body2" color="text.secondary">
                      Average Predicted Views
                    </Typography>
                  </Box>
                </Grid>
                <Grid item xs={12} sm={6} md={3}>
                  <Box textAlign="center">
                    <Typography variant="h4" color="info">
                      {safeAnalyticsData.predictions_summary.max_predicted_views?.toLocaleString() || 'N/A'}
                    </Typography>
                    <Typography variant="body2" color="text.secondary">
                      Max Predicted Views
                    </Typography>
                  </Box>
                </Grid>
                <Grid item xs={12} sm={6} md={3}>
                  <Box textAlign="center">
                    <Typography variant="h4" color="warning">
                      {safeAnalyticsData.predictions_summary.min_predicted_views?.toLocaleString() || 'N/A'}
                    </Typography>
                    <Typography variant="body2" color="text.secondary">
                      Min Predicted Views
                    </Typography>
                  </Box>
                </Grid>
              </Grid>
            </Paper>
          </Grid>
        </Grid>
      )}

      {/* Engagement Authenticity Analysis */}
      <Grid container spacing={3} sx={{ mb: 4 }}>
        <Grid item xs={12} md={6}>
          <Paper sx={{ p: 2 }}>
            <Typography variant="h6" gutterBottom>
              Engagement Authenticity Analysis
            </Typography>
            {/* Only render chart if there's data */}
            {engagementAuthenticityData && engagementAuthenticityData.some(item => item.value > 0) ? (
              <ResponsiveContainer width="100%" height={300}>
                <PieChart>
                  <Pie
                    data={engagementAuthenticityData}
                    cx="50%"
                    cy="50%"
                    labelLine={false}
                    label={({ name, percent }) => `${name}: ${(percent * 100).toFixed(0)}%`}
                    outerRadius={80}
                    fill="#8884d8"
                    dataKey="value"
                    animationBegin={0}
                    animationDuration={800}
                  >
                    {engagementAuthenticityData.map((entry, index) => (
                      <Cell key={`cell-${index}`} fill={entry.color} />
                    ))}
                  </Pie>
                  <Tooltip 
                    formatter={(value, name) => [`${value.toLocaleString()}`, name]}
                    contentStyle={{ backgroundColor: 'rgba(255, 255, 255, 0.95)', border: '1px solid #ccc' }}
                  />
                  <Legend />
                </PieChart>
              </ResponsiveContainer>
            ) : (
              <Box sx={{ 
                display: 'flex', 
                alignItems: 'center', 
                justifyContent: 'center', 
                height: 300,
                color: 'rgba(255, 255, 255, 0.6)',
                flexDirection: 'column',
                gap: 2
              }}>
                <Security sx={{ fontSize: 48, opacity: 0.5 }} />
                <Typography variant="body1">
                  No engagement data available
                </Typography>
                <Typography variant="body2" sx={{ opacity: 0.7 }}>
                  Waiting for analytics data...
                </Typography>
              </Box>
            )}
            {safeAnalyticsData.engagement_authenticity && (
              <Box sx={{ mt: 2, display: 'flex', justifyContent: 'space-around' }}>
                <Box textAlign="center">
                  <Typography variant="caption" color="text.secondary">Real Engagement</Typography>
                  <Typography variant="body2" color="success.main">
                    {safeAnalyticsData.engagement_authenticity.real?.toLocaleString() || 0}
                  </Typography>
                </Box>
                <Box textAlign="center">
                  <Typography variant="caption" color="text.secondary">Fake Engagement</Typography>
                  <Typography variant="body2" color="error.main">
                    {safeAnalyticsData.engagement_authenticity.fake?.toLocaleString() || 0}
                  </Typography>
                </Box>
              </Box>
            )}
          </Paper>
        </Grid>
        <Grid item xs={12} md={6}>
          <Paper sx={{ p: 2 }}>
            <Typography variant="h6" gutterBottom>
              Engagement Quality Metrics
            </Typography>
            <Box sx={{ height: 300, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
              {safeAnalyticsData.engagement_authenticity ? (
                <Box sx={{ textAlign: 'center' }}>
                  <Typography variant="h4" color="primary" sx={{ mb: 2 }}>
                    {safeAnalyticsData.engagement_authenticity.real > 0 ? 
                      ((safeAnalyticsData.engagement_authenticity.real / (safeAnalyticsData.engagement_authenticity.real + safeAnalyticsData.engagement_authenticity.fake)) * 100).toFixed(1) : 0}%
                  </Typography>
                  <Typography variant="body1" color="text.secondary" sx={{ mb: 3 }}>
                    Authentic Engagement Rate
                  </Typography>
                  
                  <Grid container spacing={2} sx={{ textAlign: 'left' }}>
                    <Grid item xs={12}>
                      <Box sx={{ display: 'flex', justifyContent: 'space-between', mb: 1 }}>
                        <Typography variant="body2">Real Engagement:</Typography>
                        <Typography variant="body2" sx={{ fontWeight: 'bold', color: 'success.main' }}>
                          {safeAnalyticsData.engagement_authenticity.real?.toLocaleString() || 0}
                        </Typography>
                      </Box>
                      <Box sx={{ 
                        height: 8, 
                        bgcolor: 'grey.300', 
                        borderRadius: 4, 
                        overflow: 'hidden',
                        mb: 2
                      }}>
                        <Box 
                          sx={{
                            height: '100%',
                            width: `${safeAnalyticsData.engagement_authenticity.real > 0 ? 
                              (safeAnalyticsData.engagement_authenticity.real / (safeAnalyticsData.engagement_authenticity.real + safeAnalyticsData.engagement_authenticity.fake)) * 100 : 0}%`,
                            bgcolor: 'success.main',
                            transition: 'width 0.3s ease'
                          }}
                        />
                      </Box>
                    </Grid>
                    <Grid item xs={12}>
                      <Box sx={{ display: 'flex', justifyContent: 'space-between', mb: 1 }}>
                        <Typography variant="body2">Fake Engagement:</Typography>
                        <Typography variant="body2" sx={{ fontWeight: 'bold', color: 'error.main' }}>
                          {safeAnalyticsData.engagement_authenticity.fake?.toLocaleString() || 0}
                        </Typography>
                      </Box>
                      <Box sx={{ 
                        height: 8, 
                        bgcolor: 'grey.300', 
                        borderRadius: 4, 
                        overflow: 'hidden'
                      }}>
                        <Box 
                          sx={{
                            height: '100%',
                            width: `${safeAnalyticsData.engagement_authenticity.fake > 0 ? 
                              (safeAnalyticsData.engagement_authenticity.fake / (safeAnalyticsData.engagement_authenticity.real + safeAnalyticsData.engagement_authenticity.fake)) * 100 : 0}%`,
                            bgcolor: 'error.main',
                            transition: 'width 0.3s ease'
                          }}
                        />
                      </Box>
                    </Grid>
                  </Grid>
                </Box>
              ) : (
                <Typography variant="body2" color="text.secondary">
                  No engagement data available
                </Typography>
              )}
            </Box>
          </Paper>
        </Grid>
      </Grid>

      {/* Top Performing Content Section */}
      {safeAnalyticsData.top_performing_content && safeAnalyticsData.top_performing_content.length > 0 && (
        <Grid container spacing={3} sx={{ mb: 4 }}>
          <Grid item xs={12}>
            <Paper sx={{ p: 2 }}>
              <Typography variant="h6" gutterBottom sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                <TrendingUp color="primary" />
                Top Performing Content
              </Typography>
              <Grid container spacing={2}>
                {safeAnalyticsData.top_performing_content.map((content, index) => (
                  <Grid item xs={12} sm={6} md={12} lg={2.4} key={content.content_id}>
                    <Card 
                      sx={{ 
                        height: '100%',
                        border: index === 0 ? '2px solid' : '1px solid',
                        borderColor: index === 0 ? 'primary.main' : 'grey.300',
                        position: 'relative'
                      }}
                    >
                      {index === 0 && (
                        <Chip 
                          label="#1" 
                          color="primary" 
                          size="small"
                          sx={{ 
                            position: 'absolute',
                            top: -10,
                            right: 10,
                            fontWeight: 'bold'
                          }}
                        />
                      )}
                      <CardContent sx={{ pb: 2 }}>
                        <Typography variant="h6" color="primary" sx={{ fontWeight: 'bold', mb: 1 }}>
                          {content.predicted_views.toLocaleString()}
                        </Typography>
                        <Typography variant="body2" color="text.secondary" gutterBottom>
                          Predicted Views
                        </Typography>
                        
                        <Box sx={{ mb: 2 }}>
                          <Typography variant="body2" color="text.secondary">
                            Current: {content.current_views.toLocaleString()}
                          </Typography>
                          <Typography variant="body2" color="text.secondary">
                            Likes: {content.likes.toLocaleString()}
                          </Typography>
                        </Box>
                        
                        <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', mb: 1 }}>
                          <Typography variant="caption" color="text.secondary">
                            Engagement:
                          </Typography>
                          <Typography variant="body2" sx={{ fontWeight: 'bold' }}>
                            {content.engagement_rate.toFixed(2)}%
                          </Typography>
                        </Box>
                        
                        <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', mb: 1 }}>
                          <Typography variant="caption" color="text.secondary">
                            Growth:
                          </Typography>
                          <Chip
                            label={`${content.predicted_growth > 0 ? '+' : ''}${content.predicted_growth.toFixed(1)}%`}
                            color={content.predicted_growth > 50 ? 'success' : content.predicted_growth > 0 ? 'warning' : 'default'}
                            size="small"
                            sx={{ fontWeight: 'bold' }}
                          />
                        </Box>
                        
                        <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                          <Typography variant="caption" color="text.secondary">
                            Sentiment:
                          </Typography>
                          <Chip
                            label={content.sentiment}
                            color={
                              content.sentiment === 'positive' ? 'success' : 
                              content.sentiment === 'negative' ? 'error' : 'warning'
                            }
                            size="small"
                          />
                        </Box>
                      </CardContent>
                    </Card>
                  </Grid>
                ))}
              </Grid>
            </Paper>
          </Grid>
        </Grid>
      )}

      {/* Recent Analyses and Quick Actions */}
      <Grid container spacing={3}>
        <Grid item xs={12} md={8}>
          <Paper sx={{ p: 2 }}>
            <Typography variant="h6" gutterBottom>
              Recent Analyses
            </Typography>
            <List>
              {recentAnalyses.map((analysis) => (
                <ListItem key={analysis.id} divider>
                  <ListItemText
                    primary={analysis.type}
                    secondary={`${analysis.timestamp} - Accuracy: ${analysis.accuracy}`}
                  />
                  <Chip 
                    label={analysis.status} 
                    color={analysis.status === 'Completed' ? 'success' : 'warning'}
                    size="small"
                  />
                </ListItem>
              ))}
            </List>
          </Paper>
        </Grid>
        <Grid item xs={12} md={4}>
          <Paper sx={{ p: 2 }}>
            <Typography variant="h6" gutterBottom>
              Quick Actions
            </Typography>
            <Box sx={{ display: 'flex', flexDirection: 'column', gap: 2 }}>
              <Button
                variant="contained"
                startIcon={<CloudUpload />}
                onClick={() => navigate('/upload')}
                sx={{
                  background: 'linear-gradient(45deg, #6a11cb, #2575fc)',
                  color: 'white',
                  fontWeight: 600,
                  borderRadius: '12px',
                  padding: '12px 24px',
                  boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)',
                  transition: 'all 0.3s ease',
                  '&:hover': {
                    background: 'linear-gradient(45deg, #2575fc, #6a11cb)',
                    transform: 'translateY(-2px)',
                    boxShadow: '0 8px 30px rgba(106, 17, 203, 0.5)',
                    '&:active': {
                      transform: 'translateY(0)',
                      boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)'
                    }
                  }
                }}
              >
                Upload Data
              </Button>
              <Button
                variant="outlined"
                startIcon={<LucideBrain size={20} />}
                onClick={() => navigate('/sentiment')}
                sx={{
                  background: 'linear-gradient(45deg, #6a11cb, #2575fc)',
                  color: 'white',
                  fontWeight: 600,
                  borderRadius: '12px',
                  padding: '12px 24px',
                  border: '2px solid transparent',
                  backgroundClip: 'padding-box',
                  boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)',
                  transition: 'all 0.3s ease',
                  '&:hover': {
                    background: 'linear-gradient(45deg, #2575fc, #6a11cb)',
                    transform: 'translateY(-2px)',
                    boxShadow: '0 8px 30px rgba(106, 17, 203, 0.5)',
                    '&:active': {
                      transform: 'translateY(0)',
                      boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)'
                    }
                  }
                }}
              >
                Sentiment Analysis
              </Button>
              <Button
                variant="outlined"
                startIcon={<LucideTrendingUp size={20} />}
                onClick={() => navigate('/prediction')}
                sx={{
                  background: 'linear-gradient(45deg, #6a11cb, #2575fc)',
                  color: 'white',
                  fontWeight: 600,
                  borderRadius: '12px',
                  padding: '12px 24px',
                  border: '2px solid transparent',
                  backgroundClip: 'padding-box',
                  boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)',
                  transition: 'all 0.3s ease',
                  '&:hover': {
                    background: 'linear-gradient(45deg, #2575fc, #6a11cb)',
                    transform: 'translateY(-2px)',
                    boxShadow: '0 8px 30px rgba(106, 17, 203, 0.5)',
                    '&:active': {
                      transform: 'translateY(0)',
                      boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)'
                    }
                  }
                }}
              >
                Predict Popularity
              </Button>
              <Button
                variant="contained"
                color="secondary"
                startIcon={<Speed />}
                onClick={() => navigate('/live-prediction')}
                sx={{
                  background: 'linear-gradient(45deg, #6a11cb, #2575fc)',
                  color: 'white',
                  fontWeight: 600,
                  borderRadius: '12px',
                  padding: '12px 24px',
                  boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)',
                  transition: 'all 0.3s ease',
                  '&:hover': {
                    background: 'linear-gradient(45deg, #2575fc, #6a11cb)',
                    transform: 'translateY(-2px)',
                    boxShadow: '0 8px 30px rgba(106, 17, 203, 0.5)',
                    '&:active': {
                      transform: 'translateY(0)',
                      boxShadow: '0 4px 20px rgba(106, 17, 203, 0.3)'
                    }
                  }
                }}
              >
                Live Prediction
              </Button>
            </Box>
          </Paper>
        </Grid>
      </Grid>

      {loading && (
        <Box sx={{ width: '100%', mt: 2 }}>
          <LinearProgress sx={{ 
            '& .MuiLinearProgress-bar': {
              background: 'rgba(255, 255, 255, 0.8)'
            },
            background: 'rgba(255, 255, 255, 0.2)'
          }} />
        </Box>
      )}
      </Paper>
      </Grid>
      </Grid>
      </Box>
    </Box>
        </>
      )}
    </>
    </ErrorBoundary>
  );
};

export default Dashboard;
